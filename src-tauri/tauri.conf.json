{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MusicApp",
  "version": "1.0.0",
  "identifier": "com.mars.musicapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MusicApp",
        "width": 400,
        "height": 600,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": true
        
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/**"
        ]
      },
      "csp": null
      
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["MP3s/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
